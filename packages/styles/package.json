{
  "name": "@chrome-ext/styles",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/content-script.css",
  "scripts": {
    "dev": "tsx scripts/watch.ts",
    "build": "tsc --noEmit && tsx scripts/build.ts",
