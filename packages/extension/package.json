{
  "name": "@chrome-ext/extension",
  "version": "1.0.0",
  "type": "module",
  "displayName": "Chrome Extension",
  "description": "A Chrome extension",
  "scripts": {
    "dev": "tsx scripts/watcher.ts",
    "build": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@chrome-ext/background": "workspace:*",
    "@chrome-ext/content-script": "workspace:*",
    "@chrome-ext/options": "workspace:*",
    "@chrome-ext/page-bridge": "workspace:*",
    "@chrome-ext/popup": "workspace:*",
    "@chrome-ext/styles": "workspace:*"
  },
  "devDependencies": {
    "@kami-ui/eslint-config": "^0.0.6",
    "@types/chrome": "^0.2.1",
    "@types/node": "^26.1.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "eslint": "9.39.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
