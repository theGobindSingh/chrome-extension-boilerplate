{
  "name": "@chrome-ext/popup",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/popup.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "exports": {
    ".": {
      "import": "./dist/popup.js",
      "require": "./dist/popup.js"
    }
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@chrome-ext/shared-types": "workspace:*",
    "@kami-ui/eslint-config": "^0.0.6",
    "@types/chrome": "^0.2.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "9.39.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2"
  }
}
